{
  "info": {
    "name": "SMCar.mn API",
    "description": "SMCar.mn бүх API endpoint-ууд (apicars.info + бидний backend)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apicars_url",
      "value": "https://apicars.info"
    },
    {
      "key": "local_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "api_key",
      "value": "cbf43d28797551703928b870bd361f72"
    },
    {
      "key": "admin_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "apicars.info",
      "item": [
        {
          "name": "Машин жагсаалт авах",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/cars?page=1&limit=20&sortBy=scraped_at&sortOrder=desc",
              "host": ["{{apicars_url}}"],
              "path": ["api", "cars"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "sortBy", "value": "scraped_at" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "brand", "value": "", "disabled": true },
                { "key": "model", "value": "", "disabled": true },
                { "key": "yearFrom", "value": "", "disabled": true },
                { "key": "yearTo", "value": "", "disabled": true },
                { "key": "priceFrom", "value": "", "disabled": true },
                { "key": "priceTo", "value": "", "disabled": true },
                { "key": "fuelType", "value": "", "disabled": true },
                { "key": "transmission", "value": "", "disabled": true },
                { "key": "color", "value": "", "disabled": true },
                { "key": "maxMileage", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Нэг машин авах",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/cars/:id",
              "host": ["{{apicars_url}}"],
              "path": ["api", "cars", ":id"],
              "variable": [
                { "key": "id", "value": "MACHINE_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Машины бүрэн мэдээлэл",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/cars/:id/full",
              "host": ["{{apicars_url}}"],
              "path": ["api", "cars", ":id", "full"],
              "variable": [
                { "key": "id", "value": "MACHINE_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Машин статистик",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/cars/stats",
              "host": ["{{apicars_url}}"],
              "path": ["api", "cars", "stats"]
            }
          }
        },
        {
          "name": "Үнийн задаргаа (Pricing Breakdown)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalPrice\": 13290000,\n  \"bodyType\": \"SUV\",\n  \"isKrw\": true\n}"
            },
            "url": {
              "raw": "{{apicars_url}}/api/cars/pricing-breakdown",
              "host": ["{{apicars_url}}"],
              "path": ["api", "cars", "pricing-breakdown"]
            }
          }
        },
        {
          "name": "Захиалга илгээх (Reservation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "Бат" },
                { "key": "lastName", "value": "Дорж" },
                { "key": "email", "value": "bat@example.com" },
                { "key": "phone", "value": "+97699001122" },
                { "key": "car", "value": "{\"id\":\"123\"}" },
                { "key": "comment", "value": "Тест захиалга" }
              ]
            },
            "url": {
              "raw": "{{apicars_url}}/api/reservations",
              "host": ["{{apicars_url}}"],
              "path": ["api", "reservations"]
            }
          }
        },
        {
          "name": "Нийтийн тохиргоо авах",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/business-settings/public",
              "host": ["{{apicars_url}}"],
              "path": ["api", "business-settings", "public"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth (apicars.info)",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set('admin_token', jsonData.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"your_username\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{apicars_url}}/api/auth/login",
              "host": ["{{apicars_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Token шинэчлэх (Refresh)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token\"\n}"
            },
            "url": {
              "raw": "{{apicars_url}}/api/auth/refresh",
              "host": ["{{apicars_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Token шалгах (Verify)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{apicars_url}}/api/auth/verify",
              "host": ["{{apicars_url}}"],
              "path": ["api", "auth", "verify"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token\"\n}"
            },
            "url": {
              "raw": "{{apicars_url}}/api/auth/logout",
              "host": ["{{apicars_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Бидний Backend",
      "item": [
        {
          "name": "Баннер",
          "item": [
            {
              "name": "Бүх баннер авах",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{local_url}}/api/banners",
                  "host": ["{{local_url}}"],
                  "path": ["api", "banners"]
                }
              }
            },
            {
              "name": "Баннер нэмэх",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "title", "value": "Тест баннер" },
                    { "key": "linkUrl", "value": "https://smcar.mn" },
                    { "key": "position", "value": "home_top" },
                    { "key": "order", "value": "1" },
                    { "key": "image", "type": "file", "src": "" }
                  ]
                },
                "url": {
                  "raw": "{{local_url}}/api/banners",
                  "host": ["{{local_url}}"],
                  "path": ["api", "banners"]
                }
              }
            },
            {
              "name": "Баннер засах",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "title", "value": "Шинэчилсэн баннер" },
                    { "key": "position", "value": "home_top" },
                    { "key": "isActive", "value": "true" }
                  ]
                },
                "url": {
                  "raw": "{{local_url}}/api/banners/:id",
                  "host": ["{{local_url}}"],
                  "path": ["api", "banners", ":id"],
                  "variable": [
                    { "key": "id", "value": "BANNER_ID_HERE" }
                  ]
                }
              }
            },
            {
              "name": "Баннер устгах",
              "request": {
                "method": "DELETE",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  }
                ],
                "url": {
                  "raw": "{{local_url}}/api/banners/:id",
                  "host": ["{{local_url}}"],
                  "path": ["api", "banners", ":id"],
                  "variable": [
                    { "key": "id", "value": "BANNER_ID_HERE" }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Тохиргоо",
          "item": [
            {
              "name": "Тохиргоо авах",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{local_url}}/api/settings",
                  "host": ["{{local_url}}"],
                  "path": ["api", "settings"]
                }
              }
            },
            {
              "name": "Тохиргоо хадгалах",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"siteName\": \"SMCar Mongolia\",\n  \"phone\": \"+976 9900-1122\",\n  \"email\": \"info@smcar.mn\",\n  \"address\": \"Улаанбаатар\",\n  \"socialLinks\": {\n    \"facebook\": \"https://facebook.com/smcar\",\n    \"instagram\": \"https://instagram.com/smcar\"\n  }\n}"
                },
                "url": {
                  "raw": "{{local_url}}/api/settings",
                  "host": ["{{local_url}}"],
                  "path": ["api", "settings"]
                }
              }
            }
          ]
        },
        {
          "name": "Ханш",
          "item": [
            {
              "name": "Ханш авах",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{local_url}}/api/exchange-rate",
                  "host": ["{{local_url}}"],
                  "path": ["api", "exchange-rate"]
                }
              }
            },
            {
              "name": "Ханш өөрчлөх",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"wonToMnt\": 2.8,\n  \"euroToMnt\": 3800\n}"
                },
                "url": {
                  "raw": "{{local_url}}/api/exchange-rate",
                  "host": ["{{local_url}}"],
                  "path": ["api", "exchange-rate"]
                }
              }
            }
          ]
        },
        {
          "name": "Upload",
          "item": [
            {
              "name": "Баннер зураг upload",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "image", "type": "file", "src": "" }
                  ]
                },
                "url": {
                  "raw": "{{local_url}}/api/upload/banner",
                  "host": ["{{local_url}}"],
                  "path": ["api", "upload", "banner"]
                }
              }
            },
            {
              "name": "Лого upload",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "image", "type": "file", "src": "" }
                  ]
                },
                "url": {
                  "raw": "{{local_url}}/api/upload/logo",
                  "host": ["{{local_url}}"],
                  "path": ["api", "upload", "logo"]
                }
              }
            }
          ]
        },
        {
          "name": "Image Proxy",
          "item": [
            {
              "name": "Зураг proxy-аар авах",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{local_url}}/api/image-proxy?url=https://example.com/image.jpg",
                  "host": ["{{local_url}}"],
                  "path": ["api", "image-proxy"],
                  "query": [
                    { "key": "url", "value": "https://example.com/image.jpg" }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
